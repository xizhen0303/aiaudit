# ── Server ────────────────────────────────────────────────────
PORT=3000

# REQUIRED in production: generate with `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
SESSION_SECRET=change-this-to-a-long-random-string-in-production

# ── Environment ───────────────────────────────────────────────
# Set to 'production' to enable HTTPS-only cookies and combined access log
NODE_ENV=development

# ── File upload limits ─────────────────────────────────────────
# Single file max size in megabytes (default: 500)
MAX_FILE_SIZE_MB=500

# ── Admin ──────────────────────────────────────────────────────
# Default admin credentials are created by `npm run seed` (admin / admin123).
# Change the password immediately after first login in a production environment:
#   node -e "const db=require('./server/db'),b=require('bcryptjs');
#            db.prepare('UPDATE admin_users SET password_hash=? WHERE username=?')
#              .run(b.hashSync('YOUR_NEW_PASSWORD',10),'admin');"
